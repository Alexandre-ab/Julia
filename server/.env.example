# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/projet-j
# Pour MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/projet-j?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your-secret-key-here-min-32-characters-required
JWT_EXPIRATION=24h

# OpenAI API
GEMINI_API_KEY=AIzr...-here
OPENAI_MODEL=gpt-4

# Expo Push Notifications
EXPO_ACCESS_TOKEN=your-expo-access-token-here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:19006

# Application Settings
INVITE_TOKEN_EXPIRATION_DAYS=7
SESSION_REPORT_MESSAGE_THRESHOLD=10
